# PostgreSQL connection string — provided automatically by Railway Postgres plugin
DATABASE_URL=postgresql://user:password@localhost:5432/bgo_fantasy_platform

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# API-Football (api-sports.io) — for live player stats
APIFOOTBALL_API_KEY=

# Optional overrides
APP_ENV=production
APP_URL=https://your-app.railway.app
SESSION_COOKIE_NAME=bgo_games_session
